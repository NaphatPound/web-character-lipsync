# Copy this file to .env and fill in values

# Ollama local API for emotion/tone analysis
# Point to your Ollama instance (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama model for emotion tagging (must be already pulled via `ollama pull <model>`)
# glm-4.7-flash is fast and supports Thai/English. Other options: gpt-oss:20b
OLLAMA_MODEL=glm-4.7-flash:latest

# Path to SadTalker directory (default: ./models/SadTalker)
SADTALKER_DIR=./models/SadTalker

# Max upload size in bytes (default: 10485760 = 10 MB)
MAX_FILE_SIZE=10485760

# File cleanup age in seconds (default: 3600 = 1 hour)
CLEANUP_AGE_SECONDS=3600
